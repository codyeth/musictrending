# Telegram
TELEGRAM_BOT_TOKEN=
ADMIN_USER_IDS=123456789

# OpenRouter AI
# Single key (legacy):
OPENROUTER_API_KEY=
# Multiple keys — rotated automatically on 402/429 (optional):
# OPENROUTER_API_KEYS=sk-or-key1,sk-or-key2,sk-or-key3
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Free model — no credits needed (20 req/min). Alternatives:
#   google/gemini-2.0-flash-exp:free
#   meta-llama/llama-3.3-70b-instruct:free
#   deepseek/deepseek-r1:free
OPENROUTER_MODEL=google/gemma-3-4b-it:free

# Reddit (optional — get from reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=music-tool/1.0

# Spotify (optional — get from developer.spotify.com)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Scoring thresholds
ALERT_SCORE_THRESHOLD=70
RUSH_THRESHOLD=80
WATCH_THRESHOLD=60

# Dashboard
DASHBOARD_PORT=3000

# Database
DATABASE_URL=file:./data/music.db
