# Telegram
TELEGRAM_BOT_TOKEN=
ADMIN_USER_IDS=123456789

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Reddit (optional — get from reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=music-tool/1.0

# Spotify (optional — get from developer.spotify.com)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Scoring thresholds
ALERT_SCORE_THRESHOLD=70
RUSH_THRESHOLD=80
WATCH_THRESHOLD=60

# Dashboard
DASHBOARD_PORT=3000

# Database
DATABASE_URL=file:./data/music.db
