generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TrendSource {
  SPOTIFY
  APPLE_MUSIC
  SHAZAM
  BILLBOARD
  REDDIT
  NICONICO
  MELON
  GOOGLE_TRENDS
  MANUAL
}

enum TrendStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DecisionAction {
  APPROVE
  WATCH
  REJECT
}

model Trend {
  id          Int         @id @default(autoincrement())
  externalId  String      @unique
  source      TrendSource
  title       String
  artist      String
  url         String?
  thumbnail   String?
  market      String?
  rawData     String?

  type        String      @default("REMIX")
  totalScore  Int         @default(0)
  urgency     String?
  vibe        String?
  aiSuggest   String?
  scores      String?
  alerted     Boolean     @default(false)

  status      TrendStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  decision    Decision?
}

model Decision {
  id        Int            @id @default(autoincrement())
  trendId   Int            @unique
  trend     Trend          @relation(fields: [trendId], references: [id])
  action    DecisionAction
  note      String?
  decidedAt DateTime       @default(now())
}
